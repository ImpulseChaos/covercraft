# Supabase — from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe — from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# App URL (change to your production URL when deploying)
NEXT_PUBLIC_APP_URL=http://localhost:3000
